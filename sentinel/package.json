  "description": "Always-on daemon for Claude Code — persistent sessions, file-based inbox, autonomous watchers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sentinel": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
