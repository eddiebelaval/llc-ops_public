  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chokidar": "^4.0.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
