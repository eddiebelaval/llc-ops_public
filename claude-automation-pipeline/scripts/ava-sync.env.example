# Ava Memory Sync — Cross-platform memory synchronization
# Syncs memories between Telegram (hydra.db) and Parallax web (Supabase)
#
# Copy to ~/.hydra/config/ava-sync.env and fill in values.
# Daemon: ~/.hydra/daemons/ava-memory-sync.sh
# Schedule: Every 30 minutes via launchd

# Parallax Supabase connection (production)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# User's auth.users.id in Parallax
USER_ID="YOUR_USER_UUID"

# Sync behavior
SYNC_BATCH_SIZE=20
SYNC_LOG_RETENTION_DAYS=30
